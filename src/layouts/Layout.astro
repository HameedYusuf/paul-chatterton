---
import '../styles/global.css';
import site from '../data/site.json';

interface Props {
  title: string;
  description?: string;
}
const { title, description = site.siteDescription } = Astro.props;

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} · {site.siteName}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>

  <!-- NAVIGATION -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" style="background:#0d0d0d;border-bottom:1px solid rgba(255,255,255,0.08);">
    <div class="container">
      <div class="flex items-center justify-between h-16">

        <!-- Logo / name -->
        <a href="/" class="text-white font-semibold text-base whitespace-nowrap hover:text-accent transition-colors" style="color:#fff;">
          {site.siteName}
        </a>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-1">
          <!-- About dropdown -->
          <div class="relative group">
            <a
              href="/about"
              class={`px-3 py-2 text-sm rounded transition-colors ${currentPath.startsWith('/about') || currentPath === '/impact' ? 'text-white' : 'text-[#a3a3a3] hover:text-white'}`}
            >
              About ▾
            </a>
            <div class="absolute top-full left-0 pt-2 hidden group-hover:block">
              <div class="rounded-lg overflow-hidden shadow-xl" style="background:#1a1a1a;border:1px solid rgba(255,255,255,0.08);min-width:220px;">
                {site.aboutDropdownLinks.map(al => (
                  <a
                    href={al.href}
                    target={al.external ? '_blank' : undefined}
                    rel={al.external ? 'noopener noreferrer' : undefined}
                    class="block px-4 py-3 text-sm text-[#a3a3a3] hover:text-white hover:bg-white/5 transition-colors"
                  >
                    {al.label}
                  </a>
                ))}
              </div>
            </div>
          </div>

          {site.navLinks.filter(l => l.href !== '/').map(link => (
            <a
              href={link.href}
              class={`px-3 py-2 text-sm rounded transition-colors ${currentPath.startsWith(link.href) ? 'text-white' : 'text-[#a3a3a3] hover:text-white'}`}
            >
              {link.label}
            </a>
          ))}
        </div>

        <!-- Mobile hamburger -->
        <button id="menu-btn" class="md:hidden p-2 text-[#a3a3a3] hover:text-white transition-colors" aria-label="Toggle menu">
          <svg id="icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-white/5 mt-0">
        <a href="/" class="block px-2 py-3 text-sm text-[#a3a3a3] hover:text-white transition-colors border-b border-white/5">Home</a>
        {site.navLinks.filter(l => l.href !== '/').map(link => (
          <a href={link.href} class="block px-2 py-3 text-sm text-[#a3a3a3] hover:text-white transition-colors border-b border-white/5">
            {link.label}
          </a>
        ))}
        <div class="pt-2">
          <p class="px-2 py-1 text-xs text-white/40 uppercase tracking-widest">About</p>
          {site.aboutDropdownLinks.map(al => (
            <a
              href={al.href}
              target={al.external ? '_blank' : undefined}
              class="block px-4 py-2 text-sm text-[#a3a3a3] hover:text-white transition-colors"
            >
              {al.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </nav>

  <!-- PAGE CONTENT (offset for fixed nav) -->
  <main class="pt-16">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer style="background:#0d0d0d;border-top:1px solid rgba(255,255,255,0.08);" class="pt-16 pb-8">
    <div class="container">
      <div class="grid md:grid-cols-3 gap-12 mb-12">

        <!-- Left: tagline -->
        <div class="md:col-span-1">
          <p class="text-white font-semibold text-lg mb-3">{site.footerTagline}</p>
          <p class="text-sm leading-relaxed" style="color:#a3a3a3;">{site.footerBody}</p>
        </div>

        <!-- Nav col -->
        <div>
          <p class="label mb-4">Navigate</p>
          <ul class="space-y-2">
            {[
              { label: 'Impact',        href: '/impact' },
              { label: 'About',         href: '/about' },
              { label: 'Publications',  href: '/publications' },
              { label: 'Media',         href: '/media' },
              { label: 'Roles',         href: '/roles' },
              { label: 'Collaborate',   href: '/collaborate' },
            ].map(l => (
              <li><a href={l.href} class="text-sm text-[#a3a3a3] hover:text-white transition-colors">{l.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Connect col -->
        <div>
          <p class="label mb-4">Connect</p>
          <ul class="space-y-2">
            <li>
              <a href={site.googleScholarUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-[#a3a3a3] hover:text-white transition-colors">
                Google Scholar ↗
              </a>
            </li>
            <li>
              <a href={site.universityUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-[#a3a3a3] hover:text-white transition-colors">
                University of Leeds ↗
              </a>
            </li>
            <li>
              <a href={`mailto:${site.email}`} class="text-sm text-[#a3a3a3] hover:text-white transition-colors">
                {site.email}
              </a>
            </li>
          </ul>
        </div>
      </div>

      <hr style="border-color:rgba(255,255,255,0.08);" class="mb-6" />
      <p class="text-xs" style="color:#a3a3a3;">© 2026 {site.siteName}. Built with Astro.</p>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('icon-open');
    const iconClose = document.getElementById('icon-close');

    btn?.addEventListener('click', () => {
      const isOpen = !menu?.classList.contains('hidden');
      menu?.classList.toggle('hidden', isOpen);
      iconOpen?.classList.toggle('hidden', !isOpen);
      iconClose?.classList.toggle('hidden', isOpen);
    });
  </script>
  <script is:inline>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on('init', function(user) {
        if (!user) {
          window.netlifyIdentity.on('login', function() {
            document.location.href = '/admin/index.html';
          });
        }
      });
    }
    if (window.location.hash && (window.location.hash.includes('invite_token') || window.location.hash.includes('recovery_token'))) {
      window.netlifyIdentity && window.netlifyIdentity.open();
    }
  </script>
</body>
</html>
