---
import '../styles/global.css';
import site from '../data/site.json';

interface Props {
  title: string;
  description?: string;
}
const { title, description = site.siteDescription } = Astro.props;

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} · {site.siteName}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,400;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />
  <script is:inline>
    // Apply saved theme immediately to avoid flash
    if (localStorage.getItem('theme') === 'light') document.documentElement.classList.add('light');
    // Redirect invite/recovery tokens to admin page where the CMS widget handles them
    var hash = window.location.hash;
    if (hash && (hash.includes('invite_token') || hash.includes('recovery_token'))) {
      window.location.replace('/admin/index.html' + hash);
    }
  </script>
</head>
<body>

  <!-- HEADER BANNER (scrolls with page) -->
  <header style="background:var(--color-nav-bg);border-bottom:1px solid var(--color-nav-border);">
    <div class="container py-6 text-center">

      <!-- Mobile: name + hamburger row -->
      <div class="flex items-center justify-between md:hidden">
        <a href="/" class="font-bold text-xl uppercase tracking-widest hover:text-[#22c55e] transition-colors" style="color:var(--color-text);">
          {site.siteName}
        </a>
        <div class="flex items-center gap-2">
          <button id="theme-toggle-mobile" aria-label="Toggle theme" class="p-2 rounded-md transition-colors" style="color:var(--color-muted);background:var(--color-surface);border:1px solid var(--color-border);">
            <svg id="icon-sun-m" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg id="icon-moon-m" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
          <button id="menu-btn" class="p-2 transition-colors" style="color:var(--color-muted)" aria-label="Toggle menu">
            <svg id="icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
            <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Desktop: full centred banner -->
      <div class="hidden md:block">
        <a href="/" class="inline-block group">
          <h1 class="font-bold uppercase tracking-[0.18em] leading-none group-hover:text-[#22c55e] transition-colors" style="color:var(--color-text);font-size:2.75rem;">
            {site.siteName}
          </h1>
        </a>
        <!-- Decorative rule -->
        <div class="mx-auto mt-3 mb-3" style="width:56px;border-top:1px solid var(--color-border);"></div>
        <!-- Tagline -->
        <p class="italic mb-2" style="color:var(--color-text);font-size:1.1rem;">{site.headerTagline}</p>
        <!-- Descriptor -->
        <p class="uppercase tracking-[0.18em] text-xs" style="color:var(--color-muted);">{site.navSubtitle}</p>
      </div>

    </div>
  </header>

  <!-- STICKY NAV STRIP -->
  <nav id="navbar" class="sticky top-0 z-50" style="background:var(--color-nav-bg);border-bottom:1px solid var(--color-nav-border);">
    <div class="container">

      <!-- Desktop nav strip -->
      <div class="hidden md:flex items-center justify-center h-10 relative">

        <!-- Centred links -->
        <div class="flex items-center gap-0">
          <a href="/" class="px-3 py-2 text-xs font-bold uppercase tracking-widest transition-colors hover:text-[#22c55e]"
            style={`color:${currentPath === '/' ? 'var(--color-text)' : 'var(--color-muted)'};${currentPath === '/' ? 'border-bottom:2px solid var(--color-accent);' : ''}`}>
            Home
          </a>

          <!-- About dropdown -->
          <div class="relative group">
            <a href="/about"
              class="px-3 py-2 text-xs font-bold uppercase tracking-widest transition-colors hover:text-[#22c55e] inline-block"
              style={`color:${currentPath.startsWith('/about') || currentPath === '/press-kit' ? 'var(--color-text)' : 'var(--color-muted)'};${currentPath.startsWith('/about') || currentPath === '/press-kit' ? 'border-bottom:2px solid var(--color-accent);' : ''}`}>
              About ▾
            </a>
            <div class="absolute top-full left-0 pt-1 hidden group-hover:block z-50">
              <div class="rounded-lg overflow-hidden shadow-xl" style="background:var(--color-surface);border:1px solid var(--color-border);min-width:220px;">
                {site.aboutDropdownLinks.map(al => (
                  <a
                    href={al.href}
                    target={al.external ? '_blank' : undefined}
                    rel={al.external ? 'noopener noreferrer' : undefined}
                    class="block px-4 py-3 text-sm hover:bg-black/5 transition-colors"
                    style="color:var(--color-muted)"
                  >
                    {al.label}
                  </a>
                ))}
              </div>
            </div>
          </div>

          {site.navLinks.filter(l => l.href !== '/' && l.href !== '/collaborate').map(link => (
            <a
              href={link.href}
              class="px-3 py-2 text-xs font-bold uppercase tracking-widest transition-colors hover:text-[#22c55e]"
              style={`color:${currentPath.startsWith(link.href) ? 'var(--color-text)' : 'var(--color-muted)'};${currentPath.startsWith(link.href) ? 'border-bottom:2px solid var(--color-accent);' : ''}`}
            >
              {link.label}
            </a>
          ))}

          <a href="/collaborate" class="ml-2 px-3 py-1 text-xs font-bold uppercase tracking-widest rounded-md bg-[#22c55e] text-black hover:bg-[#16a34a] transition-colors">
            Let's Collaborate
          </a>
        </div>

        <!-- Theme toggle (absolute right) -->
        <div class="absolute right-0">
          <button id="theme-toggle" aria-label="Toggle theme" class="p-2 rounded-md transition-colors" style="color:var(--color-muted);background:var(--color-surface);border:1px solid var(--color-border);">
            <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
        </div>

      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden pb-4 border-t mt-0" style="border-color:var(--color-nav-border);">
        <a href="/" class="block px-2 py-3 text-sm font-bold uppercase tracking-widest transition-colors hover:text-[#22c55e]" style="color:var(--color-muted);border-bottom:1px solid var(--color-border);">Home</a>
        <a href="/about" class="block px-2 py-3 text-sm font-bold uppercase tracking-widest transition-colors hover:text-[#22c55e]" style="color:var(--color-muted);border-bottom:1px solid var(--color-border);">About</a>
        {site.navLinks.filter(l => l.href !== '/' && l.href !== '/collaborate').map(link => (
          <a href={link.href} class="block px-2 py-3 text-sm font-bold uppercase tracking-widest transition-colors hover:text-[#22c55e]" style="color:var(--color-muted);border-bottom:1px solid var(--color-border);">{link.label}</a>
        ))}
        <a href="/collaborate" class="block mx-2 my-3 px-4 py-2 text-sm font-bold uppercase tracking-widest text-center rounded-md bg-[#22c55e] text-black hover:bg-[#16a34a] transition-colors">Let's Collaborate</a>
        <div class="pt-1 px-2">
          <p class="py-1 text-xs uppercase tracking-widest" style="color:var(--color-muted);opacity:0.5;">About links</p>
          {site.aboutDropdownLinks.map(al => (
            <a href={al.href} target={al.external ? '_blank' : undefined} class="block py-2 text-sm transition-colors hover:text-[#22c55e]" style="color:var(--color-muted);border-bottom:1px solid var(--color-border);">{al.label}</a>
          ))}
        </div>
      </div>

    </div>
  </nav>

  <!-- PAGE CONTENT -->
  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <!-- FOOTER (Tim Jackson minimal style — theme-aware) -->
  <footer class="site-footer">
    <div class="container py-8">

      <div class="grid md:grid-cols-[1fr_auto_1fr] gap-8 items-start">

        <!-- Left: Search -->
        <form id="site-search">
          <button type="submit" class="footer-search-btn">Search</button>
          <input
            id="search-input"
            type="text"
            placeholder="Type here and press enter..."
            class="footer-search-input"
          />
        </form>

        <!-- Centre: minimal links -->
        <div class="flex items-start justify-center pt-1">
          <p class="footer-links">
            <a href="/press-kit" class="footer-link">Press Kit</a>
            {' | '}
            <a href={`mailto:${site.email}`} class="footer-link">Contact</a>
          </p>
        </div>

        <!-- Right: profile icons -->
        <div class="flex justify-end items-start gap-4 pt-1">

          <!-- Email -->
          <a href={`mailto:${site.email}`} title="Email Paul" class="footer-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
          </a>

          <!-- Google Scholar -->
          <a href={site.googleScholarUrl} target="_blank" rel="noopener noreferrer" title="Google Scholar" class="footer-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 9a8 8 0 0 1 7.162 4.44L24 9.5z"/>
            </svg>
          </a>

          <!-- University of Leeds -->
          <a href={site.universityUrl} target="_blank" rel="noopener noreferrer" title="University of Leeds Profile" class="footer-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 3 1 9l11 6 9-4.91V17h2V9L12 3zM5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82z"/>
            </svg>
          </a>

          <!-- Blog -->
          <a href="/blog" title="Blog" class="footer-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/>
            </svg>
          </a>

        </div>
      </div>

      <!-- Copyright -->
      <div class="mt-8 flex justify-end">
        <p class="footer-copy">© 2026 {site.siteName}. Built with Astro.</p>
      </div>

    </div>
  </footer>

  <script is:inline>
    document.getElementById('site-search')?.addEventListener('submit', function(e) {
      e.preventDefault();
      var q = document.getElementById('search-input')?.value?.trim();
      if (q) window.open('https://www.google.com/search?q=' + encodeURIComponent(q + ' site:paul-chatterton.com'), '_blank');
    });
  </script>

  <script is:inline>
    // Mobile menu
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('icon-open');
    const iconClose = document.getElementById('icon-close');
    btn?.addEventListener('click', function() {
      const isOpen = !menu?.classList.contains('hidden');
      menu?.classList.toggle('hidden', isOpen);
      iconOpen?.classList.toggle('hidden', !isOpen);
      iconClose?.classList.toggle('hidden', isOpen);
    });

    // Theme toggle (desktop + mobile)
    var html = document.documentElement;

    function applyTheme(theme) {
      var suns  = [document.getElementById('icon-sun'),  document.getElementById('icon-sun-m')];
      var moons = [document.getElementById('icon-moon'), document.getElementById('icon-moon-m')];
      if (theme === 'light') {
        html.classList.add('light');
        suns.forEach(function(el)  { el && el.classList.remove('hidden'); });
        moons.forEach(function(el) { el && el.classList.add('hidden'); });
      } else {
        html.classList.remove('light');
        suns.forEach(function(el)  { el && el.classList.add('hidden'); });
        moons.forEach(function(el) { el && el.classList.remove('hidden'); });
      }
    }

    var saved = localStorage.getItem('theme') || 'dark';
    applyTheme(saved);

    function toggleTheme() {
      var next = html.classList.contains('light') ? 'dark' : 'light';
      localStorage.setItem('theme', next);
      applyTheme(next);
    }
    document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
    document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);
  </script>
</body>
</html>
