---
interface Stat {
  number: string;
  label: string;
}
interface Props {
  stats: Stat[];
}
const { stats } = Astro.props;
---

<div class="grid grid-cols-3 gap-8 py-12" style="border-top:1px solid rgba(255,255,255,0.08);border-bottom:1px solid rgba(255,255,255,0.08);">
  {stats.map(s => (
    <div class="text-center">
      <p class="text-4xl md:text-5xl font-bold text-white mb-2">{s.number}</p>
      <p class="text-sm" style="color:#a3a3a3;">{s.label}</p>
    </div>
  ))}
</div>
