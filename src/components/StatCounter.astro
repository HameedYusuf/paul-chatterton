---
interface Stat {
  number: string;
  label: string;
}
interface Props {
  stats: Stat[];
}
const { stats } = Astro.props;
---

<div class="grid grid-cols-3 gap-8 py-12" style="border-top:1px solid var(--color-border);border-bottom:1px solid var(--color-border);">
  {stats.map(s => (
    <div class="text-center">
      <p class="text-4xl md:text-5xl font-bold mb-2" style="color:var(--color-text)">{s.number}</p>
      <p class="text-sm" style="color:var(--color-muted)">{s.label}</p>
    </div>
  ))}
</div>
