---
interface Props {
  emoji: string;
  heading: string;
  body: string;
}
const { emoji, heading, body } = Astro.props;
---

<div class="p-6 rounded-xl flex flex-col gap-3" style="background:var(--color-surface);border:1px solid var(--color-border);">
  <span class="text-3xl">{emoji}</span>
  <h3 class="text-base">{heading}</h3>
  <p class="text-sm leading-relaxed">{body}</p>
</div>
