---
interface Props {
  heading?: string;
  body?: string;
  cta?: string;
  href?: string;
}
const {
  heading = "Ready to Make Change?",
  body = "After three decades of research and activism, I'm always looking for partners who want to create sustainable, just, and resilient futures.",
  cta = "Start a Conversation",
  href = "/collaborate",
} = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="rounded-xl p-12 text-center" style="background:var(--color-surface);border:1px solid var(--color-border);">
      <h2 class="mb-4">{heading}</h2>
      <p class="mb-8 max-w-xl mx-auto">{body}</p>
      <a href={href} class="btn-primary">{cta} →</a>
    </div>
  </div>
</section>
