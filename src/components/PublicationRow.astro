---
interface Props {
  year: number | string;
  citation: string;
  type: string;
  url?: string;
}
const { year, citation, type, url } = Astro.props;

const typeColors: Record<string, string> = {
  'Journal Article': 'rgba(34,197,94,0.12)',
  'Book':            'rgba(59,130,246,0.12)',
  'Report':          'rgba(168,85,247,0.12)',
  'Comment Piece':   'rgba(251,146,60,0.12)',
  'Book Chapter':    'rgba(59,130,246,0.08)',
  'Preprint':        'rgba(100,116,139,0.2)',
};
const typeText: Record<string, string> = {
  'Journal Article': '#22c55e',
  'Book':            '#60a5fa',
  'Report':          '#c084fc',
  'Comment Piece':   '#fb923c',
  'Book Chapter':    '#93c5fd',
  'Preprint':        '#94a3b8',
};
---

<div class="flex items-start gap-4 py-4" style="border-bottom:1px solid rgba(255,255,255,0.06);">
  <span class="pill pill-green shrink-0 mt-0.5">{year}</span>
  <div class="flex-1 min-w-0">
    {url ? (
      <a href={url} target="_blank" rel="noopener noreferrer" class="text-sm text-white hover:text-[#22c55e] transition-colors leading-relaxed">
        {citation}
      </a>
    ) : (
      <p class="text-sm text-white leading-relaxed">{citation}</p>
    )}
  </div>
  <span
    class="pill shrink-0 text-xs hidden sm:inline-block"
    style={`background:${typeColors[type] ?? 'rgba(255,255,255,0.08)'};color:${typeText[type] ?? '#a3a3a3'};`}
  >
    {type}
  </span>
</div>
