---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';
import PublicationRow from '../components/PublicationRow.astro';
import SectionHeading from '../components/SectionHeading.astro';
import pubs from '../data/publications.json';
import pages from '../data/pages.json';

const totalCount = pubs.books.length + pubs.journalArticles.length + pubs.reports.length + pubs.commentPieces.length;
const pg = pages.publications;
---

<Layout title={pg.heroTitle} description={pg.heroSubtitle}>

  {pg.heroImage && (
    <div class="w-full" style="height:340px;overflow:hidden;">
      <img src={pg.heroImage} alt={pg.heroTitle} class="w-full h-full object-cover" />
    </div>
  )}

  <!-- Hero -->
  <section class="section" style="background:var(--color-bg);">
    <div class="container">
      <h1 class="mb-4">{pg.heroTitle}</h1>
      <p class="max-w-2xl text-lg">{pg.heroSubtitle}</p>
      <div class="flex flex-wrap gap-3 mt-8" id="pub-filters">
        {[
          { label: 'All',             filter: 'all' },
          { label: 'Books',           filter: 'books' },
          { label: 'Journal Articles',filter: 'journal-articles' },
          { label: 'Reports',         filter: 'reports' },
          { label: 'Comment Pieces',  filter: 'comment-pieces' },
        ].map((b, i) => (
          <button
            class={`pub-filter-btn${i === 0 ? ' active' : ''}`}
            data-filter={b.filter}
          >{b.label}</button>
        ))}
      </div>
    </div>
  </section>

  <!-- Books -->
  <section id="books" data-section="books" class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <SectionHeading heading="Books" />
      {pubs.books.map(p => <PublicationRow year={p.year} citation={p.citation} type={p.type} url={p.url || undefined} />)}
    </div>
  </section>

  <!-- Journal Articles -->
  <section id="journal-articles" data-section="journal-articles" class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <SectionHeading heading="Journal Articles" />
      {pubs.journalArticles.map(p => <PublicationRow year={p.year} citation={p.citation} type={p.type} url={p.url || undefined} />)}
    </div>
  </section>

  <!-- Reports -->
  <section id="reports" data-section="reports" class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <SectionHeading heading="Reports" />
      {pubs.reports.map(p => <PublicationRow year={p.year} citation={p.citation} type={p.type} url={p.url || undefined} />)}
    </div>
  </section>

  <!-- Comment Pieces -->
  <section id="comment-pieces" data-section="comment-pieces" class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <SectionHeading heading="Comment Pieces" />
      {pubs.commentPieces.map(p => <PublicationRow year={p.year} citation={p.citation} type={p.type} url={p.url || undefined} />)}
    </div>
  </section>

  <CTABanner />

  <script is:inline>
    var filterBtns = document.querySelectorAll('.pub-filter-btn');
    var sections   = document.querySelectorAll('[data-section]');

    filterBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var filter = btn.getAttribute('data-filter');

        // Update active button
        filterBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');

        // Show / hide sections
        sections.forEach(function(sec) {
          if (filter === 'all' || sec.getAttribute('data-section') === filter) {
            sec.style.display = '';
          } else {
            sec.style.display = 'none';
          }
        });

        // Scroll to first visible section
        if (filter !== 'all') {
          var target = document.querySelector('[data-section="' + filter + '"]');
          if (target) {
            setTimeout(function() {
              target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 50);
          }
        } else {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });
    });
  </script>
</Layout>
