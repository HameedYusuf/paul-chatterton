---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';
import PublicationRow from '../components/PublicationRow.astro';
import SectionHeading from '../components/SectionHeading.astro';
import pubs from '../data/publications.json';
import pages from '../data/pages.json';

const totalCount = pubs.books.length + pubs.journalArticles.length + pubs.reports.length + pubs.commentPieces.length;
const pg = pages.publications;
---

<Layout title={pg.heroTitle} description={pg.heroSubtitle}>

  {pg.heroImage && (
    <div class="w-full" style="height:340px;overflow:hidden;">
      <img src={pg.heroImage} alt={pg.heroTitle} class="w-full h-full object-cover" />
    </div>
  )}

  <!-- Hero -->
  <section class="section" style="background:var(--color-bg);">
    <div class="container">
      <h1 class="mb-4">{pg.heroTitle}</h1>
      <p class="max-w-2xl text-lg">{pg.heroSubtitle}</p>
      <div class="flex flex-wrap gap-6 mt-8">
        {[
          { label: 'Books',           href: '#books' },
          { label: 'Journal Articles',href: '#journal-articles' },
          { label: 'Reports',         href: '#reports' },
          { label: 'Comment Pieces',  href: '#comment-pieces' },
        ].map(l => (
          <a href={l.href} class="text-sm font-medium hover:text-[#22c55e] transition-colors" style="color:var(--color-muted);">{l.label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- Books -->
  <section id="books" class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <SectionHeading heading="Books" />
      {pubs.books.map(p => <PublicationRow year={p.year} citation={p.citation} type={p.type} url={p.url || undefined} />)}
    </div>
  </section>

  <!-- Journal Articles -->
  <section id="journal-articles" class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <SectionHeading heading="Journal Articles" />
      {pubs.journalArticles.map(p => <PublicationRow year={p.year} citation={p.citation} type={p.type} url={p.url || undefined} />)}
    </div>
  </section>

  <!-- Reports -->
  <section id="reports" class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <SectionHeading heading="Reports" />
      {pubs.reports.map(p => <PublicationRow year={p.year} citation={p.citation} type={p.type} url={p.url || undefined} />)}
    </div>
  </section>

  <!-- Comment Pieces -->
  <section id="comment-pieces" class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <SectionHeading heading="Comment Pieces" />
      {pubs.commentPieces.map(p => <PublicationRow year={p.year} citation={p.citation} type={p.type} url={p.url || undefined} />)}
    </div>
  </section>

  <CTABanner />
</Layout>
