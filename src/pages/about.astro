---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';
import about from '../data/about.json';
import site from '../data/site.json';
import home from '../data/home.json';
---

<Layout title="About" description={`Professor ${site.siteName} — academic, activist and author working at the University of Leeds.`}>

  <div class="container" style="padding-top:2.5rem;padding-bottom:4rem;">
    <div class="grid lg:grid-cols-[240px_1fr_260px] gap-10 items-start">

      <!-- ── LEFT SIDEBAR ── -->
      <aside class="lg:sticky lg:top-24">

        <!-- Portrait -->
        <div class="overflow-hidden mb-0" style="aspect-ratio:3/4;">
          <img
            src={site.aboutImage || site.heroImage}
            alt={`Professor ${site.siteName}`}
            class="w-full h-full object-cover object-top"
            onerror="this.parentElement.style.background='var(--color-surface)'"
          />
        </div>

        <!-- Quick nav links (Tim Jackson style) -->
        <nav class="mt-1">
          {[
            { label: 'Publications',  href: '/publications' },
            { label: 'Projects',      href: '/projects' },
            { label: 'Media',         href: '/media' },
            { label: 'Impact',        href: '/impact' },
            { label: 'Press Kit',     href: '/press-kit' },
            { label: 'Collaborate',   href: '/collaborate' },
          ].map(l => (
            <a
              href={l.href}
              class="block px-3 py-2.5 text-sm font-medium transition-colors hover:bg-black/5 dark:hover:bg-white/5"
              style="color:var(--color-muted);border-bottom:1px solid var(--color-border);"
            >
              {l.label}
            </a>
          ))}
        </nav>

      </aside>

      <!-- ── CENTRE: main bio ── -->
      <div>

        <!-- RÉSUMÉ heading (Tim Jackson style) -->
        <h2
          class="text-2xl font-bold uppercase tracking-widest mb-3"
          style="color:var(--color-text);letter-spacing:0.15em;"
        >
          Résumé
        </h2>
        <hr style="border-color:var(--color-border);margin-bottom:1.75rem;" />

        <!-- Bio paragraphs -->
        <div class="space-y-5 text-base leading-relaxed mb-10" style="color:var(--color-muted);">
          {about.bio.map((para: string) => (
            <p>{para}</p>
          ))}
        </div>

        <!-- Research section -->
        <h3
          class="text-lg font-bold mb-3"
          style="color:var(--color-text);"
        >
          {about.researchSectionTitle}
        </h3>
        <hr style="border-color:var(--color-border);margin-bottom:1.25rem;" />
        <p class="text-base leading-relaxed mb-10" style="color:var(--color-muted);">
          {about.researchText}
        </p>

        <!-- Community & Activism section -->
        <h3
          class="text-lg font-bold mb-3"
          style="color:var(--color-text);"
        >
          {about.communitySectionTitle}
        </h3>
        <hr style="border-color:var(--color-border);margin-bottom:1.25rem;" />
        <p class="text-base leading-relaxed mb-10" style="color:var(--color-muted);">
          {about.communityText}
        </p>

        <!-- Academic Profile links -->
        <h3
          class="text-lg font-bold mb-3"
          style="color:var(--color-text);"
        >
          Academic Profiles
        </h3>
        <hr style="border-color:var(--color-border);margin-bottom:1.25rem;" />
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={site.googleScholarUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary" style="font-size:0.875rem;padding:0.5rem 1.25rem;">
            Google Scholar ↗
          </a>
          <a href={site.universityUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary" style="font-size:0.875rem;padding:0.5rem 1.25rem;">
            University of Leeds Profile ↗
          </a>
        </div>

      </div>

      <!-- ── RIGHT SIDEBAR ── -->
      <aside class="lg:sticky lg:top-24 space-y-5">

        <!-- Featured Books -->
        {home.featuredBooks.map(b => (
          <div class="sidebar-widget">
            <p class="sidebar-widget-title">{b.title.toUpperCase()}</p>
            {b.image ? (
              <a href={b.url} target="_blank" rel="noopener noreferrer" class="block group mt-1">
                <img
                  src={b.image}
                  alt={b.title}
                  class="w-full object-cover mb-3 group-hover:opacity-90 transition-opacity"
                />
                <p class="text-xs leading-snug" style="color:var(--color-muted);">{b.description}</p>
              </a>
            ) : (
              <a href={b.url} target="_blank" rel="noopener noreferrer" class="block group">
                <p class="text-sm font-semibold mb-1 group-hover:text-[#22c55e] transition-colors" style="color:var(--color-text)">{b.title}</p>
                <p class="text-xs" style="color:var(--color-muted)">{b.description}</p>
              </a>
            )}
          </div>
        ))}

        <!-- By the Numbers -->
        <div class="sidebar-widget">
          <p class="sidebar-widget-title">By the Numbers</p>
          <div class="space-y-3">
            {about.stats.map(s => (
              <div class="flex items-center justify-between py-1" style="border-bottom:1px solid var(--color-border);">
                <span class="text-xs" style="color:var(--color-muted)">{s.label}</span>
                <span class="text-lg font-bold" style="color:var(--color-text)">{s.number}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Roles -->
        <div class="sidebar-widget">
          <p class="sidebar-widget-title">Key Roles</p>
          <div class="space-y-0">
            {about.roles.map((r: string) => (
              <div class="py-2" style="border-bottom:1px solid var(--color-border);">
                <p class="text-xs leading-snug" style="color:var(--color-muted)">{r}</p>
              </div>
            ))}
          </div>
          <a href="/roles" class="text-link text-xs font-medium mt-3 inline-block">View All Roles →</a>
        </div>

      </aside>

    </div>
  </div>

  <CTABanner
    heading={about.ctaHeading}
    body={about.ctaBody}
    cta={about.ctaLabel}
    href={about.ctaHref}
  />

</Layout>
