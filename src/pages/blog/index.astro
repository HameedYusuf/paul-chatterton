---
import Layout from '../../layouts/Layout.astro';
import CTABanner from '../../components/CTABanner.astro';
import { getSubstackPosts } from '../../lib/substack';
import pages from '../../data/pages.json';

const posts = await getSubstackPosts();
const pg = pages.blog;
---

<Layout title={pg.heroTitle} description={pg.heroSubtitle}>

  {pg.heroImage && (
    <div class="w-full" style="height:340px;overflow:hidden;">
      <img src={pg.heroImage} alt={pg.heroTitle} class="w-full h-full object-cover" />
    </div>
  )}

  <section class="section" style="background:var(--color-bg);">
    <div class="container">
      <h1 class="mb-4">{pg.heroTitle}</h1>
      <p class="text-lg max-w-xl">{pg.heroSubtitle}</p>
      <p class="mt-2 text-sm">{posts.length} pieces</p>
    </div>
  </section>

  <section class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-6">
        {posts.map(post => (
          <div class="card p-6 flex flex-col">
            <div class="flex items-center gap-3 mb-4">
              <span class="pill pill-green">{post.date}</span>
              <span class="text-xs" style="color:var(--color-muted);">Urban Futures Now</span>
            </div>
            <h3 class="text-base mb-3 flex-1">{post.title}</h3>
            <p class="text-sm mb-4" style="color:var(--color-muted);">{post.excerpt}</p>
            <a
              href={post.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium"
              style="color:var(--color-accent);"
            >
              Read on Substack →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner />
</Layout>
