---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import CTABanner from '../../components/CTABanner.astro';
import Card from '../../components/Card.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import pages from '../../data/pages.json';

const projects = (await getCollection('projects')).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const pg = pages.projects;
---

<Layout title={pg.heroTitle} description={pg.heroSubtitle}>

  {pg.heroImage && (
    <div class="w-full" style="height:340px;overflow:hidden;">
      <img src={pg.heroImage} alt={pg.heroTitle} class="w-full h-full object-cover" />
    </div>
  )}

  <section class="section" style="background:var(--color-bg);">
    <div class="container">
      <h1 class="mb-4">{pg.heroTitle}</h1>
      <p class="max-w-xl text-lg">{pg.heroSubtitle}</p>
    </div>
  </section>

  <section class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <div class="grid md:grid-cols-3 gap-6">
        {projects.map(p => (
          <Card
            title={p.data.title}
            role={p.data.role}
            description={p.data.description}
            impact={p.data.impact}
            href={`/projects/${p.slug}`}
            image={p.data.image}
          />
        ))}
      </div>
    </div>
  </section>

  <CTABanner />
</Layout>
