---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';
import Card from '../components/Card.astro';
import StatCounter from '../components/StatCounter.astro';
import PublicationRow from '../components/PublicationRow.astro';
import SectionHeading from '../components/SectionHeading.astro';
import home from '../data/home.json';
import site from '../data/site.json';
---

<Layout title="Home">

  <!-- HERO + SIDEBAR (two-column from top) -->
  <section class="section" style="background:var(--color-bg);border-bottom:1px solid var(--color-border);">
    <div class="container">
      <div class="grid lg:grid-cols-[3fr_2fr] gap-12 items-start">

        <!-- Left: hero content -->
        <div>
          <p class="label mb-4">{home.hero.label}</p>
          <h1 class="mb-6">{home.hero.title}</h1>
          <p class="text-base mb-8 max-w-lg" style="color:var(--color-muted)">{home.hero.body}</p>
          <div class="flex flex-wrap gap-4 mb-10">
            <a href={home.hero.ctaPrimaryHref} class="btn-primary">{home.hero.ctaPrimary}</a>
            <a href={home.hero.ctaSecondaryHref} class="btn-secondary">{home.hero.ctaSecondary}</a>
          </div>
          <!-- Paul's photo sits below the CTAs -->
          <div class="rounded-xl overflow-hidden max-w-sm" style="border:1px solid var(--color-border);">
            <img
              src={site.heroImage}
              alt={`Professor ${site.siteName}`}
              class="w-full object-cover object-top"
              style="max-height:360px;"
              onerror="this.style.display='none';"
            />
          </div>
        </div>

        <!-- Right: sticky sidebar -->
        <aside class="lg:sticky lg:top-24 space-y-6">

          <!-- Featured Books -->
          <div class="sidebar-widget">
            <p class="sidebar-widget-title">Featured Books</p>
            <div class="space-y-4">
              {home.featuredBooks.map(b => (
                <a href={b.url} target="_blank" rel="noopener noreferrer" class="block group">
                  <p class="text-sm font-semibold leading-snug mb-1 group-hover:text-[#22c55e] transition-colors" style="color:var(--color-text)">{b.title}</p>
                  <p class="text-xs" style="color:var(--color-muted)">{b.description}</p>
                </a>
              ))}
            </div>
          </div>

          <!-- Upcoming Talks -->
          <div class="sidebar-widget">
            <p class="sidebar-widget-title">Upcoming Talks</p>
            <div class="space-y-3">
              {home.upcomingTalks.map(t => (
                <div class="pb-3" style="border-bottom:1px solid var(--color-border);">
                  <p class="text-sm font-medium" style="color:var(--color-text)">{t.venue}</p>
                  <p class="text-xs mt-0.5" style="color:var(--color-accent)">{t.date}</p>
                </div>
              ))}
            </div>
            <a href="/media" class="text-link text-xs font-medium mt-3 inline-block">View All Talks →</a>
          </div>

          <!-- Most Read -->
          <div class="sidebar-widget">
            <p class="sidebar-widget-title">Most Read</p>
            <div>
              {home.mostRead.map((item, i) => (
                <a href={item.url} target="_blank" rel="noopener noreferrer" class="flex gap-3 items-start py-2 group" style="border-bottom:1px solid var(--color-border);">
                  <span class="text-xs font-bold mt-0.5 shrink-0" style="color:var(--color-accent)">{String(i + 1).padStart(2, '0')}</span>
                  <span class="text-xs leading-snug group-hover:text-[#22c55e] transition-colors" style="color:var(--color-muted)">{item.title}</span>
                </a>
              ))}
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <div class="container">
    <StatCounter stats={home.stats} />
  </div>

  <!-- FEATURED PROJECTS -->
  <section class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <SectionHeading label={home.projectsSectionLabel} heading="Transformative Projects" />
      <div class="grid md:grid-cols-3 gap-6">
        {home.featuredProjects.map(p => (
          <Card
            title={p.title}
            role={p.role}
            description={p.description}
            impact={p.impact || undefined}
            href={p.href}
            image={p.image || undefined}
          />
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/projects" class="text-link font-medium">View All Projects →</a>
      </div>
    </div>
  </section>

  <!-- LATEST PUBLICATIONS -->
  <section class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <SectionHeading label={home.publicationsSectionLabel} heading="Latest Publications" />
      <div>
        {home.latestPublications.map(p => (
          <PublicationRow year={p.year} citation={p.citation} type={p.type} url={p.url || undefined} />
        ))}
      </div>
      <div class="mt-8">
        <a href="/publications" class="text-link font-medium">View All Publications →</a>
      </div>
    </div>
  </section>

  <!-- MEDIA & TALKS -->
  <section class="section" style="background:var(--color-section-alt);border-top:1px solid var(--color-border);">
    <div class="container">
      <SectionHeading label={home.mediaSectionLabel} heading="Media & Talks" />
      <div class="grid md:grid-cols-3 gap-6">
        {home.featuredMedia.map(m => (
          <a href={m.url} target="_blank" rel="noopener noreferrer" class="card p-6 hover:border-[#22c55e]/30 transition-colors block">
            <p class="label mb-2">{m.platform}</p>
            <h3 class="text-base">{m.title}</h3>
            <p class="text-sm mt-3" style="color:var(--color-accent);">Listen / Watch →</p>
          </a>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/media" class="text-link font-medium">View All Media →</a>
      </div>
    </div>
  </section>

  <CTABanner heading={home.ctaHeading} body={home.ctaBody} cta={home.ctaLabel} href={home.ctaHref} />
</Layout>
