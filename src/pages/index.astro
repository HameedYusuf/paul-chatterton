---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';
import Card from '../components/Card.astro';
import StatCounter from '../components/StatCounter.astro';
import PublicationRow from '../components/PublicationRow.astro';
import SectionHeading from '../components/SectionHeading.astro';
import home from '../data/home.json';
import site from '../data/site.json';
---

<Layout title="Home">
  <!-- HERO -->
  <section class="section" style="background:#0d0d0d;">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="label mb-4">{home.hero.label}</p>
          <h1 class="mb-6">{home.hero.title}</h1>
          <p class="text-base mb-8 max-w-lg">{home.hero.body}</p>
          <div class="flex flex-wrap gap-4">
            <a href={home.hero.ctaPrimaryHref} class="btn-primary">{home.hero.ctaPrimary}</a>
            <a href={home.hero.ctaSecondaryHref} class="btn-secondary">{home.hero.ctaSecondary}</a>
          </div>
        </div>
        <div class="relative">
          <div class="rounded-xl overflow-hidden aspect-[4/5]" style="border:1px solid rgba(255,255,255,0.08);">
            <img
              src={site.heroImage}
              alt={`Professor ${site.siteName}`}
              class="w-full h-full object-cover"
              onerror="this.parentElement.style.background='#1a1a1a';this.style.display='none';"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STAT COUNTER -->
  <div class="container">
    <StatCounter stats={home.stats} />
  </div>

  <!-- TRANSFORMATIVE PROJECTS -->
  <section class="section">
    <div class="container">
      <SectionHeading
        label={home.projectsSectionLabel}
        heading="Transformative Projects"
      />
      <div class="grid md:grid-cols-3 gap-6">
        {home.featuredProjects.map(p => (
          <Card
            title={p.title}
            role={p.role}
            description={p.description}
            impact={p.impact || undefined}
            href={p.href}
            image={p.image || undefined}
          />
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/projects" class="text-link font-medium">View All Projects →</a>
      </div>
    </div>
  </section>

  <!-- TWO-COLUMN: PUBLICATIONS + SIDEBAR -->
  <section class="section" style="border-top:1px solid rgba(255,255,255,0.08);">
    <div class="container">
      <div class="grid md:grid-cols-3 gap-12">

        <!-- Main: Publications -->
        <div class="md:col-span-2">
          <SectionHeading
            label={home.publicationsSectionLabel}
            heading="Latest Publications"
          />
          <div>
            {home.latestPublications.map(p => (
              <PublicationRow year={p.year} citation={p.citation} type={p.type} url={p.url || undefined} />
            ))}
          </div>
          <div class="mt-8">
            <a href="/publications" class="text-link font-medium">View All Publications →</a>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-8">

          <!-- Books feature -->
          <div>
            <p class="label mb-4">Featured Books</p>
            <div class="space-y-4">
              {home.featuredBooks.map(b => (
                <a href={b.url} target="_blank" rel="noopener noreferrer" class="block p-4 rounded-lg hover:bg-white/5 transition-colors" style="background:#1a1a1a;border:1px solid rgba(255,255,255,0.08);">
                  <p class="text-white text-sm font-semibold leading-snug mb-1">{b.title}</p>
                  <p class="text-xs">{b.description}</p>
                </a>
              ))}
            </div>
          </div>

          <!-- Upcoming talks -->
          <div>
            <p class="label mb-4">Upcoming Talks</p>
            <div class="space-y-3">
              {home.upcomingTalks.map(t => (
                <div class="py-3" style="border-bottom:1px solid rgba(255,255,255,0.06);">
                  <p class="text-white text-sm">{t.venue}</p>
                  <p class="text-xs mt-1" style="color:#22c55e;">{t.date}</p>
                </div>
              ))}
            </div>
            <a href="/media" class="text-link text-sm font-medium mt-3 inline-block">View All Talks →</a>
          </div>

          <!-- Most read -->
          <div>
            <p class="label mb-4">Most Read</p>
            <div class="space-y-2">
              {home.mostRead.map(item => (
                <a href={item.url} target="_blank" rel="noopener noreferrer" class="block text-sm text-[#a3a3a3] hover:text-white transition-colors py-2" style="border-bottom:1px solid rgba(255,255,255,0.06);">
                  {item.title}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MEDIA STRIP -->
  <section class="section" style="background:#0d0d0d;border-top:1px solid rgba(255,255,255,0.08);">
    <div class="container">
      <SectionHeading
        label={home.mediaSectionLabel}
        heading="Media & Talks"
      />
      <div class="grid md:grid-cols-3 gap-6">
        {home.featuredMedia.map(m => (
          <a
            href={m.url}
            target="_blank"
            rel="noopener noreferrer"
            class="card p-6 hover:border-white/20 transition-colors block"
          >
            <p class="label mb-2">{m.platform}</p>
            <h3 class="text-base">{m.title}</h3>
            <p class="text-sm mt-3" style="color:#22c55e;">Listen / Watch →</p>
          </a>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/media" class="text-link font-medium">View All Media →</a>
      </div>
    </div>
  </section>

  <CTABanner heading={home.ctaHeading} body={home.ctaBody} cta={home.ctaLabel} href={home.ctaHref} />
</Layout>
