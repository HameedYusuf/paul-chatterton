---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';
import Card from '../components/Card.astro';
import { getCollection } from 'astro:content';
import home from '../data/home.json';
import site from '../data/site.json';

const projects = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 6);
---

<Layout title="Home">

  <!-- Optional hero banner image -->
  {home.heroImage && (
    <div class="w-full" style="height:340px;overflow:hidden;">
      <img src={home.heroImage} alt="Hero" class="w-full h-full object-cover" />
    </div>
  )}

  <!-- MAIN CONTENT + SIDEBAR (Tim Jackson layout) -->
  <div class="container" style="padding-top:2.5rem;padding-bottom:4rem;">
    <div class="grid lg:grid-cols-[3fr_1.2fr] gap-10 items-start">

      <!-- LEFT: main content -->
      <div>

        <!-- Welcome paragraph -->
        <p class="text-base leading-relaxed mb-8" style="color:var(--color-muted);">
          {home.welcomeText}
        </p>

        <!-- 3-column feature row: portrait + 2 books -->
        <div class="grid grid-cols-3 gap-3 mb-10">

          <!-- Portrait -->
          <a href="/about" class="block overflow-hidden" style="aspect-ratio:3/4;">
            <img
              src={site.heroImage}
              alt="Professor Paul Chatterton"
              class="w-full h-full object-cover object-top transition-opacity hover:opacity-90"
            />
          </a>

          <!-- Book 1 -->
          {home.featuredBooks[0] && (
            home.featuredBooks[0].image ? (
              <a href={home.featuredBooks[0].url} target="_blank" rel="noopener noreferrer" class="block overflow-hidden hover:opacity-90 transition-opacity" style="aspect-ratio:3/4;">
                <img src={home.featuredBooks[0].image} alt={home.featuredBooks[0].title} class="w-full h-full object-cover" />
              </a>
            ) : (
              <a href={home.featuredBooks[0].url} target="_blank" rel="noopener noreferrer" class="flex flex-col items-center justify-center p-5 text-center hover:opacity-90 transition-opacity" style="aspect-ratio:3/4;background:#1c1c2e;color:#ffffff;">
                <p class="font-bold text-base leading-tight mb-3">{home.featuredBooks[0].title}</p>
                <p class="text-xs leading-relaxed opacity-80">{home.featuredBooks[0].description}</p>
              </a>
            )
          )}

          <!-- Book 2 -->
          {home.featuredBooks[1] && (
            home.featuredBooks[1].image ? (
              <a href={home.featuredBooks[1].url} target="_blank" rel="noopener noreferrer" class="block overflow-hidden hover:opacity-90 transition-opacity" style="aspect-ratio:3/4;">
                <img src={home.featuredBooks[1].image} alt={home.featuredBooks[1].title} class="w-full h-full object-cover" />
              </a>
            ) : (
              <a href={home.featuredBooks[1].url} target="_blank" rel="noopener noreferrer" class="flex flex-col items-center justify-center p-5 text-center hover:opacity-90 transition-opacity" style="aspect-ratio:3/4;background:#1a3a2a;color:#ffffff;">
                <p class="font-bold text-base leading-tight mb-3">{home.featuredBooks[1].title}</p>
                <p class="text-xs leading-relaxed opacity-80">{home.featuredBooks[1].description}</p>
              </a>
            )
          )}

        </div>

        <!-- Projects 3×2 grid -->
        <div>
          <h3 class="text-sm font-bold uppercase tracking-widest pb-2 mb-6" style="color:var(--color-text);border-bottom:2px solid var(--color-text);">Projects</h3>
          <div class="grid md:grid-cols-2 gap-5">
            {projects.map(p => (
              <Card
                title={p.data.title}
                role={p.data.role}
                description={p.data.description}
                href={`/projects/${p.slug}`}
                image={p.data.image}
              />
            ))}
          </div>
          <div class="mt-6">
            <a href="/projects" class="text-sm text-link font-medium">View All Projects →</a>
          </div>
        </div>

      </div>

      <!-- RIGHT: sticky sidebar -->
      <aside class="lg:sticky lg:top-24 space-y-5">

        <!-- Featured Books -->
        {home.featuredBooks.map(b => (
          <div class="sidebar-widget">
            <p class="sidebar-widget-title">{b.title.toUpperCase()}</p>
            <a href={b.url} target="_blank" rel="noopener noreferrer" class="block group mt-1">
              {b.image ? (
                <img
                  src={b.image}
                  alt={b.title}
                  class="w-full object-cover mb-3 group-hover:opacity-90 transition-opacity"
                  loading="lazy"
                />
              ) : null}
              <p class="text-xs leading-snug group-hover:text-[#22c55e] transition-colors" style="color:var(--color-muted);">{b.description}</p>
            </a>
          </div>
        ))}

        <!-- Most Read -->
        <div class="sidebar-widget">
          <p class="sidebar-widget-title">Most Popular</p>
          <div>
            {home.mostRead.map((item, i) => (
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="flex gap-3 items-start py-2 group" style="border-bottom:1px solid var(--color-border);">
                <span class="text-xs font-bold mt-0.5 shrink-0" style="color:var(--color-accent)">{String(i + 1).padStart(2, '0')}</span>
                <span class="text-xs leading-snug group-hover:text-[#22c55e] transition-colors" style="color:var(--color-muted)">{item.title}</span>
              </a>
            ))}
          </div>
        </div>

        <!-- Upcoming Talks -->
        <div class="sidebar-widget">
          <p class="sidebar-widget-title">Upcoming Talks</p>
          <div class="space-y-0">
            {home.upcomingTalks.map(t => (
              <div class="py-2" style="border-bottom:1px solid var(--color-border);">
                <p class="text-sm font-medium" style="color:var(--color-text)">{t.venue}</p>
                {t.location && (
                  <p class="text-xs mt-0.5" style="color:var(--color-muted)">{t.location}</p>
                )}
                <p class="text-xs mt-0.5" style="color:var(--color-accent)">{t.date}</p>
              </div>
            ))}
          </div>
          <a href="/media" class="text-link text-xs font-medium mt-3 inline-block">View All Talks →</a>
        </div>

        <!-- Stats -->
        <div class="sidebar-widget">
          <p class="sidebar-widget-title">By the Numbers</p>
          <div class="space-y-3">
            {home.stats.map(s => (
              <div class="flex items-center justify-between py-1" style="border-bottom:1px solid var(--color-border);">
                <span class="text-xs" style="color:var(--color-muted)">{s.label}</span>
                <span class="text-lg font-bold" style="color:var(--color-text)">{s.number}</span>
              </div>
            ))}
          </div>
        </div>

      </aside>
    </div>
  </div>

  <!-- CTA: full width -->
  <CTABanner heading={home.ctaHeading} body={home.ctaBody} cta={home.ctaLabel} href={home.ctaHref} />

</Layout>
