---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';
import SectionHeading from '../components/SectionHeading.astro';
import rolesData from '../data/roles.json';
import site from '../data/site.json';
---

<Layout title="Roles & Affiliations" description={`${site.siteName}'s community and professional roles.`}>

  <section class="section" style="background:var(--color-bg);">
    <div class="container">
      <h1 class="mb-4">{rolesData.heroTitle}</h1>
      <p class="max-w-xl text-lg">{rolesData.heroSubtitle}</p>

      <!-- Stat strip -->
      <div class="flex flex-wrap gap-10 mt-8 pt-8" style="border-top:1px solid var(--color-border);">
        <div>
          <p class="text-4xl font-bold" style="color:var(--color-text);">{rolesData.roles.length}</p>
          <p class="text-sm mt-1">Total Roles</p>
        </div>
        <div>
          <p class="text-4xl font-bold" style="color:var(--color-text);">{rolesData.roles.length}</p>
          <p class="text-sm mt-1">Community Roles</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="border-top:1px solid var(--color-border);">
    <div class="container max-w-3xl">
      <SectionHeading heading="Community" />
      <ul class="space-y-1">
        {rolesData.roles.map(r => (
          <li class="py-4 flex items-center gap-4" style="border-bottom:1px solid var(--color-border);">
            <span style="color:#22c55e;" class="text-lg shrink-0">▸</span>
            {r.url ? (
              <a href={r.url} target="_blank" rel="noopener noreferrer" class="hover:text-[#22c55e] transition-colors font-medium" style="color:var(--color-text);">
                {r.title} ↗
              </a>
            ) : (
              <span class="font-medium" style="color:var(--color-text);">{r.title}</span>
            )}
          </li>
        ))}
      </ul>

      <div class="mt-12">
        <p class="label mb-4">Academic Profiles</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={site.googleScholarUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary">Google Scholar ↗</a>
          <a href={site.universityUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary">University of Leeds Profile ↗</a>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    heading={rolesData.ctaHeading}
    body={rolesData.ctaBody}
    cta={rolesData.ctaLabel}
    href={rolesData.ctaHref}
  />
</Layout>
