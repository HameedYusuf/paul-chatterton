---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';
import Card from '../components/Card.astro';
import PublicationRow from '../components/PublicationRow.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getCollection } from 'astro:content';
import impactData from '../data/impact.json';
import pubsData from '../data/publications.json';
import mediaData from '../data/media.json';

const projects = (await getCollection('projects')).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const allPubs = [
  ...pubsData.journalArticles,
  ...pubsData.books,
  ...pubsData.reports,
  ...pubsData.commentPieces,
].sort((a, b) => b.year - a.year);

const allMedia = mediaData.items;
---

<Layout title="Work & Impact" description={impactData.heroSubtitle}>

  {impactData.heroImage && (
    <div class="w-full" style="height:340px;overflow:hidden;">
      <img src={impactData.heroImage} alt={impactData.heroTitle} class="w-full h-full object-cover" />
    </div>
  )}

  <!-- Hero -->
  <section class="section" style="background:var(--color-bg);">
    <div class="container">
      <h1 class="mb-4">{impactData.heroTitle}</h1>
      <p class="max-w-2xl text-lg">{impactData.heroSubtitle}</p>
      <div class="flex flex-wrap gap-6 mt-8">
        <a href="#projects" class="group flex items-center gap-2">
          <span class="text-2xl font-bold group-hover:text-[#22c55e] transition-colors" style="color:var(--color-text);">{impactData.projectCount}</span>
          <span class="text-sm">Projects</span>
        </a>
        <a href="#publications" class="group flex items-center gap-2">
          <span class="text-2xl font-bold group-hover:text-[#22c55e] transition-colors" style="color:var(--color-text);">{impactData.publicationCount}</span>
          <span class="text-sm">Publications</span>
        </a>
        <a href="#media" class="group flex items-center gap-2">
          <span class="text-2xl font-bold group-hover:text-[#22c55e] transition-colors" style="color:var(--color-text);">{impactData.mediaCount}</span>
          <span class="text-sm">Media Items</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <SectionHeading heading="Projects" />
      <div class="grid md:grid-cols-3 gap-6">
        {projects.map(p => (
          <Card
            title={p.data.title}
            role={p.data.role}
            description={p.data.description}
            impact={p.data.impact}
            href={`/projects/${p.slug}`}
            image={p.data.image}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Publications -->
  <section id="publications" class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <SectionHeading heading="Publications" sub={`Selected recent publications. View the full list for all ${impactData.publicationCount} works.`} />
      <div>
        {allPubs.slice(0, 9).map(p => (
          <PublicationRow year={p.year} citation={p.citation} type={p.type} url={p.url || undefined} />
        ))}
      </div>
      <div class="mt-8">
        <a href="/publications" class="btn-secondary">View All Publications →</a>
      </div>
    </div>
  </section>

  <!-- Media -->
  <section id="media" class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <SectionHeading heading="Media" />
      <div class="grid md:grid-cols-3 gap-6">
        {allMedia.slice(0, 6).map(m => (
          <a href={m.url || '#'} target="_blank" rel="noopener noreferrer" class="card p-6 hover:border-white/20 transition-colors block">
            <span class="pill pill-outline mb-3 inline-block">{m.type}</span>
            <h3 class="text-base">{m.title}</h3>
            <p class="text-sm mt-3" style="color:var(--color-accent);">Watch / Listen →</p>
          </a>
        ))}
      </div>
      <div class="mt-8">
        <a href="/media" class="btn-secondary">View All Media →</a>
      </div>
    </div>
  </section>

  <CTABanner />
</Layout>
