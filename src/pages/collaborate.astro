---
import Layout from '../layouts/Layout.astro';
import PhilosophyCard from '../components/PhilosophyCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import collab from '../data/collaborate.json';
import site from '../data/site.json';
---

<Layout title="Collaborate" description="Let's work together on research, community projects, or public engagement.">

  {collab.heroImage && (
    <div class="w-full" style="height:340px;overflow:hidden;">
      <img src={collab.heroImage} alt={collab.heroTitle} class="w-full h-full object-cover" />
    </div>
  )}

  <section class="section" style="background:var(--color-bg);">
    <div class="container max-w-3xl">
      <h1 class="mb-6">{collab.heroTitle}</h1>
      <p class="text-lg max-w-2xl">{collab.heroBody}</p>
    </div>
  </section>

  <!-- Who Should Reach Out -->
  <section class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <SectionHeading heading="Who Should Reach Out?" />
      <div class="grid md:grid-cols-4 gap-5">
        {collab.whoShouldReach.map(c => <PhilosophyCard emoji={c.emoji} heading={c.heading} body={c.body} />)}
      </div>
    </div>
  </section>

  <!-- Current Interests -->
  <section class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <SectionHeading heading="Current Interests" />
      <div class="grid md:grid-cols-4 gap-5">
        {collab.currentInterests.map(c => <PhilosophyCard emoji={c.emoji} heading={c.heading} body={c.body} />)}
      </div>
    </div>
  </section>

  <!-- Get in Touch -->
  <section class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <div class="grid lg:grid-cols-[1fr_400px] gap-12 items-start">

        <!-- LEFT: Contact form -->
        <div>
          <SectionHeading heading="Send a Message" />

          <!-- Success state -->
          <div id="form-success" class="hidden p-5 rounded-xl mb-6" style="background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.3);">
            <p class="font-semibold mb-1" style="color:#22c55e;">Message sent!</p>
            <p class="text-sm" style="color:var(--color-muted);">Thanks for reaching out. Paul will be in touch soon.</p>
          </div>

          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            id="contact-form"
            class="space-y-5"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-xs font-bold uppercase tracking-widest mb-2" style="color:var(--color-muted);" for="cf-name">
                  Name <span style="color:var(--color-accent);">*</span>
                </label>
                <input id="cf-name" type="text" name="name" required placeholder="Your full name" class="collab-input" />
              </div>
              <div>
                <label class="block text-xs font-bold uppercase tracking-widest mb-2" style="color:var(--color-muted);" for="cf-org">
                  Organisation
                </label>
                <input id="cf-org" type="text" name="organisation" placeholder="University, NGO, company…" class="collab-input" />
              </div>
            </div>

            <div>
              <label class="block text-xs font-bold uppercase tracking-widest mb-2" style="color:var(--color-muted);" for="cf-email">
                Email <span style="color:var(--color-accent);">*</span>
              </label>
              <input id="cf-email" type="email" name="email" required placeholder="you@example.com" class="collab-input" />
            </div>

            <div>
              <label class="block text-xs font-bold uppercase tracking-widest mb-2" style="color:var(--color-muted);" for="cf-type">
                Type of Collaboration
              </label>
              <select id="cf-type" name="type" class="collab-input">
                <option value="">Select one…</option>
                <option>Research partnership</option>
                <option>Policy consultation</option>
                <option>Media / journalism</option>
                <option>Speaking engagement</option>
                <option>Community project</option>
                <option>Other</option>
              </select>
            </div>

            <div>
              <label class="block text-xs font-bold uppercase tracking-widest mb-2" style="color:var(--color-muted);" for="cf-message">
                Message <span style="color:var(--color-accent);">*</span>
              </label>
              <textarea
                id="cf-message"
                name="message"
                required
                rows="5"
                placeholder="Tell Paul about your project or idea…"
                class="collab-input"
                style="resize:vertical;"
              ></textarea>
            </div>

            <button type="submit" class="btn-primary">Send Message →</button>
          </form>
        </div>

        <!-- RIGHT: contact details + quote -->
        <div class="space-y-6 lg:pt-16">
          <div class="flex items-start gap-4 p-5 rounded-xl" style="background:var(--color-surface);border:1px solid var(--color-border);">
            <span class="text-2xl">✉</span>
            <div>
              <p class="font-semibold mb-1" style="color:var(--color-text);">Email directly</p>
              <a href={`mailto:${site.email}`} class="text-link text-sm">{site.email}</a>
            </div>
          </div>
          <div class="flex items-start gap-4 p-5 rounded-xl" style="background:var(--color-surface);border:1px solid var(--color-border);">
            <span class="text-2xl">🎓</span>
            <div>
              <p class="font-semibold mb-1" style="color:var(--color-text);">University Profile</p>
              <a href={site.universityUrl} target="_blank" rel="noopener noreferrer" class="text-link text-sm">
                environment.leeds.ac.uk ↗
              </a>
            </div>
          </div>

          <blockquote class="border-l-4 pl-6 py-2 mt-8" style="border-color:#22c55e;">
            <p class="text-lg italic leading-relaxed" style="color:var(--color-text);">"{collab.quote}"</p>
            <footer class="mt-3 text-sm" style="color:var(--color-muted);">{collab.quoteAttribution}</footer>
          </blockquote>
        </div>

      </div>
    </div>
  </section>

  <script is:inline>
    var form = document.getElementById('contact-form');
    var success = document.getElementById('form-success');
    form && form.addEventListener('submit', function(e) {
      e.preventDefault();
      var data = new FormData(form);
      fetch('/', { method: 'POST', body: data })
        .then(function() {
          form.style.display = 'none';
          if (success) {
            success.classList.remove('hidden');
            success.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        })
        .catch(function() {
          alert('Sorry, something went wrong. Please email directly.');
        });
    });
  </script>

</Layout>
